# AI Provider Configuration
# Options: "openai" or "anthropic"
AI_PROVIDER=anthropic

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Database Configuration
# For local development: postgresql://username@localhost:5432/database_name
# For Railway: Will be auto-provided as DATABASE_URL
DATABASE_URL=postgresql://localhost:5432/ai_candidate_matcher
